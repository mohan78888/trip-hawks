# =============================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================

# Clerk Authentication (REQUIRED)
# Development keys: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend API URL (REQUIRED for production)
# Leave empty in dev (Vite proxy handles it)
# In production: set to your deployed backend URL
# e.g. https://trip-hawks-backend.onrender.com
VITE_API_URL=


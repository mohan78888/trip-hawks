# =============================================
# BACKEND ENVIRONMENT VARIABLES
# =============================================

# MongoDB Connection (REQUIRED)
# Get from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/triphawks

# JWT Secret (REQUIRED - use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars

# Clerk Keys (REQUIRED for auth middleware)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Gemini AI (REQUIRED for AI Assistant)
# Get from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL for CORS (REQUIRED for production)
# e.g. https://trip-hawks.netlify.app
FRONTEND_URL=https://your-frontend-domain.netlify.app

# Server Port (optional, default: 5000)
PORT=5000
